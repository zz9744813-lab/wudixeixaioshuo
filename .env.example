# 小说 Agent 工作台 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================
# 安全密钥配置（生产环境必填）
# ============================================

# APP_API_KEY 用于前端访问后端的鉴权
# - 任意高强度随机串即可
# - 前端需要在 localStorage 中设置相同的 Key
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_API_KEY=your-api-key-here-change-in-production

# APP_SECRET_KEY 用于加密存储用户的 LLM API Key
# - 必须是 Fernet.generate_key() 生成的 urlsafe base64 key，不能使用普通 hex 随机串
# - 密钥泄露会导致用户 API Key 被解密，务必保管好
# - 密钥变更后，已加密的 API Key 将无法解密，需要重新配置
# 生成方法: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET_KEY=your-secret-key-here-change-in-production

# ============================================
# 环境配置
# ============================================
# 可选: development, staging, production
# 开发环境可以不配置 APP_API_KEY，生产环境必须配置
APP_ENV=development

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=sqlite:///app/data/novel_agent.db
# PostgreSQL 示例（生产推荐）:
# DATABASE_URL=postgresql://user:password@postgres:5432/novel_agent

# ============================================
# 文件存储路径
# ============================================
UPLOAD_DIR=/app/data/uploads
ARTIFACTS_DIR=/app/data/artifacts

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
# 可选: debug, info, warning, error, critical

# ============================================
# CORS 配置
# ============================================
# 开发环境（本机访问）:
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# VPS 部署（远程浏览器访问，必须填公网 IP/域名，否则前端请求被 CORS 拦截）:
CORS_ORIGINS=http://107.172.138.14:3005,http://localhost:3005,http://127.0.0.1:3000

# ============================================
# 前端配置
# ============================================
# 浏览器从此地址请求后端 API，必须是浏览器可访问的地址（不能用 localhost，除非仅本机访问）
# 开发环境: REACT_APP_API_URL=http://localhost:8000/api
# VPS 部署: 填后端公网地址
REACT_APP_API_URL=http://107.172.138.14:8000/api
